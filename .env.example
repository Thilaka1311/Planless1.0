# -----------------------------------------------------------------------------
# Planless - Environment Configuration Template
# Copy this file to `.env` and fill in the values.
# -----------------------------------------------------------------------------

# Frontend (Vite) Configuration
# -----------------------------------------------------------------------------
# Variables prefixed with VITE_ are exposed to the frontend by Vite.
# Do NOT put secrets in VITE_ variables.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend Configuration
PORT=3000
NODE_ENV=development

# Backend-only Secrets
# -----------------------------------------------------------------------------
# These variables are never exposed to the browser.
# -----------------------------------------------------------------------------

# Supabase Admin / Service Details
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Razorpay Integration (Optional in Development)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Resend Mailer API (Optional in Development)
RESEND_API_KEY=your-resend-api-key
